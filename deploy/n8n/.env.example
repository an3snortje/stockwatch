# Copy to `.env` and fill in. NEVER commit the real .env — it holds credentials.

# --- iSync Azure SQL (read-only reporting login) ---
MSSQL_SERVER=sync-jhb-01.database.windows.net
MSSQL_PORT=1433
MSSQL_DATABASE=SyncDBNOverall
MSSQL_USERNAME=SyncDBNOverallReportingUser
MSSQL_PASSWORD=

# --- SMB / CIFS share for the baseline CSVs ---
# device becomes //SMB_HOST/SMB_SHARE, e.g. //fileserver/stockwatch$
SMB_HOST=fileserver
SMB_SHARE=stockwatch/baselines
SMB_USER=
SMB_PASSWORD=
