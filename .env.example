# Copy to .env and fill in. Never commit .env.
MSSQL_SERVER=sync-jhb-01.database.windows.net
MSSQL_PORT=1433
MSSQL_DATABASE=SyncDBNOverall
MSSQL_USERNAME=
MSSQL_PASSWORD=
# Driver as installed on the client machine (see `odbcinst -q -d` on Linux)
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
# Azure SQL requires encryption with a valid certificate — leave these as-is.
MSSQL_ENCRYPT=yes
MSSQL_TRUST_SERVER_CERTIFICATE=no
