# Copy to .env and fill in. Never commit .env.
MSSQL_SERVER=isync-sql.durbanoverall.local
MSSQL_PORT=1433
MSSQL_DATABASE=iSync
MSSQL_USERNAME=inventory_reader
MSSQL_PASSWORD=
# Driver as installed on the client machine (see `odbcinst -q -d` on Linux)
MSSQL_DRIVER=ODBC Driver 18 for SQL Server
# yes | no | optional  (18+ defaults to encrypt=yes; on-prem without certs usually needs no)
MSSQL_ENCRYPT=no
MSSQL_TRUST_SERVER_CERTIFICATE=yes
